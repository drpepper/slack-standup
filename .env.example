# Get from OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# --- Socket Mode (recommended, no public URL needed) ---
# Get from Basic Information -> App-Level Tokens -> Generate Token (scope: connections:write)
SLACK_APP_TOKEN=xapp-your-app-token

# --- HTTP Mode (alternative, requires a public URL) ---
# Uncomment and remove SLACK_APP_TOKEN above to use HTTP mode instead.
# Get from Basic Information -> App Credentials -> Signing Secret
# SLACK_SIGNING_SECRET=your-signing-secret
# PORT=3000
